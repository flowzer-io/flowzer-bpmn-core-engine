@page "/instance/{InstanceGuid:guid}"
@using FlowzerFrontend.BusinessLogic
@using FlowzerFrontend.Components
@using FlowzerFrontend.Models
@using Microsoft.FluentUI.AspNetCore.Components
@using WebApiEngine.Shared
@inherits FlowzerComponentBase

@inject ExampleRestRequestBuilder ExampleRestRequestBuilder

<div class="page-stack instance-page">
    <HeaderElement BackLink="/instances">
        <LeftSide>
            <div class="entity-header">
                <div class="entity-title-row">
                    <span id="instance-name">@InstanceTitle</span>
                    <span class="status-pill @InstanceStateToneClass">@InstanceStateLabel</span>
                </div>
                <div class="entity-meta-row">
                    <span>Workflow @(_instance?.RelatedDefinitionName ?? "Loading...")</span>
                    @if (_instance != null)
                    {
                        <span>Instance @_instance.InstanceId</span>
                        <span>Definition @_instance.RelatedDefinitionId</span>
                    }
                </div>
            </div>
        </LeftSide>
        <RigthSide>
            <FluentStack Orientation="Orientation.Horizontal" Class="instance-header-actions">
                <FluentButton Appearance="Appearance.Neutral" Disabled="@(_instance == null)" @onclick="OnOpenWorkflowClick">
                    Open workflow
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" Disabled="@IsRefreshing" @onclick="OnRefreshClickAsync">
                    Refresh runtime
                </FluentButton>
            </FluentStack>
        </RigthSide>
    </HeaderElement>

    @if (_instance != null && !HasError)
    {
        <div class="summary-grid">
            <article class="summary-card">
                <span class="summary-label">Tokens</span>
                <strong class="summary-value">@TokenCount</strong>
                <span class="summary-hint">@ActiveTokenCount active and visualized in the live diagram.</span>
            </article>
            <article class="summary-card">
                <span class="summary-label">Waiting subscriptions</span>
                <strong class="summary-value">@WaitingSubscriptionCount</strong>
                <span class="summary-hint">Messages, signals, user tasks and service callbacks currently blocking progress.</span>
            </article>
            <article class="summary-card">
                <span class="summary-label">Open user tasks</span>
                <strong class="summary-value">@(_instance.UserTaskSubscriptionCount)</strong>
                <span class="summary-hint">Human interactions that can be handled from the task inbox or this runtime view.</span>
            </article>
            <article class="summary-card">
                <span class="summary-label">Message subscriptions</span>
                <strong class="summary-value">@(_instance.MessageSubscriptionCount)</strong>
                <span class="summary-hint">Use the subscription panel to inspect or trigger waiting messages.</span>
            </article>
        </div>
    }

    @if (HasError)
    {
        <div id="instance-load-error" class="inline-state-message inline-state-message-error" role="alert">
            <div class="section-title-group">
                <strong>@ErrorHeadline</strong>
                @if (!string.IsNullOrWhiteSpace(ErrorDetails))
                {
                    <span>@ErrorDetails</span>
                }
            </div>
            <div class="diagram-inline-actions">
                <FluentButton Id="instance-retry-button" Appearance="Appearance.Accent" @onclick="OnRetryClick">
                    Retry
                </FluentButton>
            </div>
        </div>
    }
    else if (_instance == null)
    {
        <div id="instance-loading-state" class="inline-state-message inline-state-message-info">Loading instance...</div>
    }
    else
    {
        <section class="surface-panel instance-diagram-surface">
            <div class="section-header">
                <div class="section-title-group">
                    <h2 class="section-title">Live diagram</h2>
                    <p class="section-subtitle">The BPMN viewer highlights active tokens so runtime state stays readable without leaving the instance page.</p>
                </div>
            </div>
            <div class="diagram-content with-diagram" id="designer-container">
                <div class="canvas" id="js-canvas"></div>
            </div>
        </section>

        <div class="instance-runtime-grid">
            <section class="surface-panel">
                <div class="section-header">
                    <div class="section-title-group">
                        <h2 class="section-title">Tokens and data</h2>
                        <p class="section-subtitle">Select a token to inspect its flow-node context, variables and output payload separately.</p>
                    </div>
                </div>

                <div class="token-browser">
                    <div class="token-browser-sidebar">
                        <FluentTreeView Items="@VariableItems" @bind-SelectedItem="@CurrentSelectedToken" />
                    </div>

                    <div class="token-browser-content">
                        <div class="token-selection-header">
                            <strong class="section-title">@SelectedTokenTitle</strong>
                            @if (!string.IsNullOrWhiteSpace(SelectedTokenFlowNodeId))
                            {
                                <span class="pill-chip">Flow node @SelectedTokenFlowNodeId</span>
                            }
                        </div>

                        <FluentTabs>
                            <FluentTab Id="token-output" Label="Output">
                                @if (SelectedTokenHasOutputData)
                                {
                                    <FluentTextArea Value="@SelectedTokenOutputJson" ReadOnly="true" Cols="80" Rows="15" />
                                }
                                else
                                {
                                    <p class="empty-state-description">The selected token has not produced output data yet.</p>
                                }
                            </FluentTab>
                            <FluentTab Id="token-variables" Label="Variables">
                                @if (SelectedTokenHasVariables)
                                {
                                    <FluentTextArea Value="@SelectedTokenVariablesJson" ReadOnly="true" Cols="80" Rows="15" />
                                }
                                else
                                {
                                    <p class="empty-state-description">No token variables are currently available for the selected token.</p>
                                }
                            </FluentTab>
                        </FluentTabs>
                    </div>
                </div>
            </section>

            <section class="surface-panel">
                <div class="section-header">
                    <div class="section-title-group">
                        <h2 class="section-title">Subscriptions</h2>
                        <p class="section-subtitle">Expand runtime subscriptions to inspect waiting messages, signals, service tasks and user tasks.</p>
                    </div>
                </div>

                @if (!Items.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-title">No runtime subscriptions</div>
                        <p class="empty-state-description">This instance currently has no waiting messages, signals, service callbacks or user tasks.</p>
                    </div>
                }
                else
                {
                    <FluentTreeView Items="@Items">
                        <ItemTemplate>
                            @if (GetTreeRelatedItem<MessageSubscriptionDto>(context.Id, out var messageItem))
                            {
                                <div class="subscription-action-row">
                                    <span>Waiting for "@messageItem.Message.Name"</span>
                                    <FluentButton Appearance="Appearance.Neutral"
                                                  @onclick="async _ => await OpenSendRestRequestAsync(ExampleRestRequestBuilder.BuildMessageRequest(messageItem.Message, _instance?.InstanceId))"
                                                  Class="tree-button">
                                        Send message
                                    </FluentButton>
                                </div>
                            }
                            else
                            {
                                @context.Text
                            }
                        </ItemTemplate>
                    </FluentTreeView>
                }
            </section>
        </div>
    }
</div>
